{
  "name": "tiny-serial",
  "version": "1.0.0",
  "description": "A small serialport library with native Rust bindings",
  "main": "index.js",
  "exports": {
    ".": {
      "types": "./serial.d.ts",
      "require": "./serial.js"
    },
    "./native": {
      "types": "./index.d.ts",
      "require": "./index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/napi-rs/package-template.git"
  },
  "license": "MIT",
  "browser": "browser.js",
  "keywords": [
    "napi-rs",
    "NAPI",
    "N-API",
    "Rust",
    "node-addon",
    "node-addon-api"
  ],
  "files": [
    "index.d.ts",
    "index.js",
    "browser.js",
    "serial.js",
    "serial.d.ts",
    "dist/"
  ],
  "napi": {
    "binaryName": "tiny-serial",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-apple-darwin"
    ]
  },
  "optionalDependencies": {
    "tiny-serial-darwin-x64": "1.0.0",
    "tiny-serial-darwin-arm64": "1.0.0",
    "tiny-serial-linux-x64-gnu": "1.0.0",
    "tiny-serial-win32-x64-msvc": "1.0.0"
  },
  "engines": {
    "node": ">= 12.22.0 < 13 || >= 14.17.0 < 15 || >= 15.12.0 < 16 || >= 16.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "bench": "node --import @oxc-node/core/register benchmark/bench.ts",
    "build": "bun run build:native && bun run build:ts",
    "build:native": "napi build --platform --release",
    "build2": "export PATH=$HOME/.cargo/bin:$PATH && napi build --platform --release && tsc -p tsconfig.build.json",
    "build:debug": "export PATH=$HOME/.cargo/bin:$PATH && napi build --platform && tsc -p tsconfig.build.json",
    "build:ts": "tsc -p tsconfig.build.json",
    "format": "run-p format:prettier format:rs format:toml",
    "format:prettier": "prettier . -w",
    "format:toml": "taplo format",
    "format:rs": "cargo fmt",
    "lint": "run-p lint:js lint:rs",
    "lint:js": "oxlint .",
    "lint:rs": "cargo clippy -- -D warnings && cargo fmt --check",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "bun test",
    "test2": "ava",
    "test:bun": "bun --bun test __test__/bun-compat.test.ts",
    "preversion": "napi build --platform && git add .",
    "version": "napi version",
    "prepare": "husky"
  },
  "devDependencies": {
    "@emnapi/core": "^1.5.0",
    "@emnapi/runtime": "^1.5.0",
    "@napi-rs/cli": "^3.2.0",
    "@oxc-node/core": "^0.0.35",
    "@serialport/parser-byte-length": "^13.0.0",
    "@serialport/parser-readline": "^13.0.0",
    "@serialport/parser-regex": "^13.0.0",
    "@taplo/cli": "^0.7.0",
    "@tybys/wasm-util": "^0.10.0",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "ava": "^7.0.0",
    "chalk": "^5.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.14.0",
    "prettier": "^3.6.2",
    "tinybench": "^6.0.0",
    "typescript": "^6.0.0"
  },
  "lint-staged": {
    "*.@(js|ts|tsx)": [
      "oxlint --fix"
    ],
    "*.@(js|ts|tsx|yml|yaml|md|json)": [
      "prettier --write"
    ],
    "*.toml": [
      "taplo format"
    ]
  },
  "ava": {
    "files": [
      "__test__/**/*.spec.ts"
    ],
    "extensions": {
      "ts": "module"
    },
    "timeout": "2m",
    "workerThreads": false,
    "environmentVariables": {
      "OXC_TSCONFIG_PATH": "./__test__/tsconfig.json"
    },
    "nodeArguments": [
      "--import",
      "@oxc-node/core/register"
    ]
  },
  "prettier": {
    "printWidth": 120,
    "semi": false,
    "trailingComma": "all",
    "singleQuote": true,
    "arrowParens": "always"
  },
  "packageManager": "bun@1.3.2"
}
