{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "lib",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": ["lib/**/*"],
  "exclude": ["node_modules", "__test__", "benchmark"]
}
